GoogleService-Info.plist
lib/firebase_options.dart   # Generated by flutterfire configure

# Firebase local config
.firebaserc
firebase_debug.log
firebase-debug.log
firestore-debug.log
ui-debug.log
database-debug.log

# ─── Android ─────────────────────────────────────────────────────────────────
android/.gradle/
android/app/debug/
android/app/profile/
android/app/release/
android/captures/
android/gradlew
android/gradlew.bat
android/local.properties          # Contains SDK path — machine-specific
android/key.properties            # Keystore credentials — SECRET
android/*.jks                     # Keystore files — SECRET
android/*.keystore                # Keystore files — SECRET
android/app/google-services.json  # Firebase Android config — SECRET

